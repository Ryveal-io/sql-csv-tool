{
  "name": "sql-csv-chomper",
  "displayName": "SQL CSV Chomper",
  "description": "Chomp through CSV files with SQL! Powered by DuckDB with column filtering, inline editing, virtual scrolling, Save As, and an MCP server for Claude/Copilot.",
  "version": "0.1.1",
  "publisher": "MarkSawczuk",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryvdx/sql-csv-tool.git"
  },
  "homepage": "https://github.com/ryvdx/sql-csv-tool#readme",
  "license": "MIT",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Data Science",
    "Other"
  ],
  "keywords": [
    "csv",
    "tsv",
    "sql",
    "duckdb",
    "data",
    "query",
    "editor",
    "mcp",
    "chomper"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:sqlCsvTool.openFile"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "sqlCsvTool.csvEditor",
        "displayName": "SQL CSV Chomper",
        "selector": [
          { "filenamePattern": "*.csv" },
          { "filenamePattern": "*.tsv" },
          { "filenamePattern": "*.tab" },
          { "filenamePattern": "*.jsonl" },
          { "filenamePattern": "*.txt" }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "sqlCsvTool.openFile",
        "title": "Open with SQL CSV Chomper",
        "icon": "$(database)"
      },
      {
        "command": "sqlCsvTool.configureMcpClaude",
        "title": "SQL CSV Chomper: Configure MCP for Claude CLI"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "sqlCsvTool.openFile",
          "when": "resourceExtname == .csv || resourceExtname == .tsv || resourceExtname == .tab || resourceExtname == .jsonl",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "sqlCsvTool.openFile",
          "when": "(resourceExtname == .csv || resourceExtname == .tsv || resourceExtname == .tab || resourceExtname == .jsonl) && activeCustomEditorId != sqlCsvTool.csvEditor",
          "group": "navigation"
        }
      ]
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "sqlCsvTool.mcp",
        "label": "SQL CSV Chomper"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package-extension": "vsce package --no-dependencies",
    "publish-extension": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
